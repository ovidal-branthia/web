---
const {
  title = 'Branthia — Consultora de IA & estudio de producto',
  description = 'Consultora de IA aplicada y estudio de producto. Del comité de dirección a producción: automatización, sistemas agénticos, producto digital y marca.',
  noindex = true,
} = Astro.props;
---
<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<!-- Google Tag Manager -->
<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-KCV26HXK');</script>
<!-- End Google Tag Manager -->

<title>{title}</title>
<meta name="description" content={description} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
{/* TEMPORAL: permite el rastreo (agentes de IA) pero impide la indexación.
    Quitar `noindex` en el lanzamiento. */}
{noindex && <meta name="robots" content="noindex, follow" />}

<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:locale" content="es_ES" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://api.fontshare.com/v2/css?f[]=satoshi@900,800,700,500,400,300&f[]=general-sans@700,600,500,400&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style is:global>
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: "Satoshi", "Inter", system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    font-feature-settings: "ss01", "ss02";
  }
  ::selection { background: #0A0A0A; color: #F1ECE2; }
  @keyframes scrollX {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes spinSeal {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    [style*="spinSeal"] { animation: none !important; }
  }
  html { scroll-behavior: smooth; }
  body::-webkit-scrollbar { width: 10px; }
  body::-webkit-scrollbar-thumb { background: rgba(10,10,10,0.25); border-radius: 99px; }
</style>
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KCV26HXK"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
<slot />
</body>
</html>
